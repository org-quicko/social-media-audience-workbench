{
  "name": "ads-audience-workbench",
  "version": "0.1.0",
  "private": true,
  "description": "Transform customer CSVs into ad platform-ready audience files for Meta, Google, LinkedIn, and X",
  "author": "Quicko",

  "main": "electron/main.js",

  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "lint": "eslint",

    "electron:dev": "concurrently --kill-others \"next dev\" \"wait-on http://localhost:3000 && electron .\"",
    "electron:build": "next build && electron-builder --dir",
    "electron:dist": "next build && electron-builder",
    "electron:dist:win": "next build && electron-builder --win",
    "electron:dist:mac": "next build && electron-builder --mac",
    "electron:dist:linux": "next build && electron-builder --linux"
  },

  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-serve": "^2.1.1",
    "jszip": "^3.10.1",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "papaparse": "^5.5.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },

  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/jszip": "^3.4.0",
    "@types/node": "^20",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.1.2",
    "electron": "^36.3.1",
    "electron-builder": "^25.1.8",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "shadcn": "^4.7.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.0",
    "typescript": "^5",
    "wait-on": "^8.0.3"
  },

  "build": {
    "appId": "com.quicko.ads-audience-workbench",
    "productName": "Ads Audience Workbench",

    "directories": {
      "output": "dist-electron"
    },

    "files": [
      "out/**/*",
      "electron/main.js",
      "node_modules/electron-serve/**/*",
      "package.json"
    ],

    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ],
      "icon": "public/icon.ico"
    },

    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },

    "mac": {
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] }
      ],
      "icon": "public/icon.icns",
      "category": "public.app-category.business"
    },

    "linux": {
      "target": [
        { "target": "AppImage", "arch": ["x64"] }
      ],
      "icon": "public/icon.png",
      "category": "Office"
    },

    "publish": {
      "provider": "github",
      "releaseType": "release"
    }
  }
}
